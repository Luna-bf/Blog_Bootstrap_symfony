{% extends 'base.html.twig' %}

{% block title %}Nouvelle publication - Blog Bootstrap
{% endblock %}

{% block body %}
	<body class="forms-body">
		<div class="shadow">

			<section class="d-flex flex-column form-div" id="create-post-div">
				{{ form_start(createPostForm, { 'attr': {'class': 'w-50 d-flex flex-column justify-content-center rounded-3'} }) }}
				<h1 class="mb-5 text-center text-light">Créer une nouvelle publication</h1>

				{#
	            La date (DateTimeImmutable) sera envoyée par le contrôleur grâce au setter "setCreatedAt". Effectuer l'envoi de
				cette donnée côté serveur est plus sécurisé car l'utilisateur n'y aura jamais accès (envoyer cette donnée via un
				formulaire lui donnerais la possibilité de modifier une donnée sensible, ce qui n'est pas désirable).
	            #}
				{{ form_row(createPostForm.title) }}
				{{ form_row(createPostForm.content) }}
				{{ form_row(createPostForm.category) }}
				{{ form_row(createPostForm.image_name) }}
				{{ form_row(createPostForm.submit) }}

				{{ form_errors(createPostForm, { 'attr': {'class': 'error-msg'} }) }}

				{{ form_end(createPostForm) }}
			</section>
		</div>
	</body>
{% endblock %}
