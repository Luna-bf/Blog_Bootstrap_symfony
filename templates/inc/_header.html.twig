{% block header %}
	{# <HEADER> #}
	<header class="px-3 bg-dark w-100 sticky-top">
		{# <NAV> #}
		<nav class="row d-flex flex-wrap justify-content-between align-items-center">
			{# <UL> #}
			<ul class="list-unstyled d-flex align-items-center m-0">
				{# <LI> (Search) #}
				<li class="col-4">
					<a class="text-white" href="#" aria-label="Search">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="mx-3" role="img" viewbox="0 0 24 24">
							<title>Search</title>
							<circle cx="10.5" cy="10.5" r="7.5"></circle>
							<path d="M21 21l-5.2-5.2"></path>
						</svg>
					</a>
				</li>
				{# FIN <LI> (Search) #}

				{# <LI> (Blog Bootstrap) #}
				<li class="col-4 text-center">
					<a class="blog-header-logo text-white text-decoration-none" href="{{ path('post_index') }}">Blog Bootstrap</a>
				</li>
				{# FIN <LI> (Blog Bootstrap) #}
				
				{# <LI> (User) #}
				<li class="col-4 d-flex justify-content-end align-items-center">
					{% if is_granted(("ROLE_USER")) %}
						<a class="text-white text-decoration-none" href="{{ path('user_index') }}">Bonjour,
							{{ app.user.username }}</a>
					{% else %}
						<a class="text-white text-decoration-none" href="{{ path('app_register') }}">Inscription</a>
						<a class="text-white text-decoration-none ms-3" href="{{ path('app_login') }}">Connexion</a>
					{% endif %}
				</li>
				{# FIN <LI> (User) #}
			</ul>
			{# FIN <UL> #}
		</nav>
		{# FIN <NAV> #}
	</header>
	{# FIN <HEADER> #}
{% endblock %}
