{% block header %}
	{# <HEADER> #}
	<header class="container border-bottom lh-1 py-3">
		{# <NAV> #}
		<nav class="row flex-nowrap justify-content-between align-items-center">
			{# <UL> #}
			<ul class="list-unstyled d-flex align-items-center m-0">
				<li class="col-4">
					<a class="link-secondary" href="#" aria-label="Search">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="mx-3" role="img" viewbox="0 0 24 24">
							<title>Search</title>
							<circle cx="10.5" cy="10.5" r="7.5"></circle>
							<path d="M21 21l-5.2-5.2"></path>
						</svg>
					</a>
				</li>
				<li class="col-4 text-center">
					<a class="blog-header-logo text-body-emphasis text-decoration-none" href="#">Blog Bootstrap</a>
				</li>
				<li class="col-4 d-flex justify-content-end align-items-center">
					{% if is_granted(("ROLE_USER")) %}
						<a class="text-secondary text-decoration-none" href="{{ path('user_index') }}">Bonjour,
							{{ app.user.username }}</a>
					{% else %}
						<a class="btn btn-sm btn-outline-secondary" href="{{ path('app_register') }}">S'inscrire</a>
						<a class="btn btn-sm btn-outline-secondary ms-3" href="{{ path('app_login') }}">Se connecter</a>
					{% endif %}
				</li>
			</ul>
			{# FIN <UL> #}
		</nav>
		{# FIN <NAV> #}
	</header>
	{# FIN <HEADER> #}
{% endblock %}
