{% extends 'base.html.twig' %}

{% block title %}Votre profil - Blog Bootstrap
{% endblock %}

{% block body %}
	{# Début MAIN #}
	<main class="container">
		<div class="banner"></div>
		<div class="d-flex flex-row justify-content-between mb-2" id="profile-div">
			<ul class="list-unstyled d-flex flex-row justify-content-center justify-content-between" id="profile-nav">
				<li>
					{# Voir si je peux définir plusieurs dossier d'upload d'image et si je peux mettre une condition, exemple :
					si le fichier provient d'une publication portant la catégorie "World", je vais stocker son image dans un
					dossier nommé "world", si c'est une photo de profil, je vais le stocker dans un dossier "profilePictures"... #}
					<figure class="w-25"><img src="/assets/imgs/profile/default-pfp.png" alt="Default profile picture" class="w-100 rounded-circle"></figure>
				</li>
				{% if not is_granted("ROLE_USER") %}
					<li class="fs-5 align-items-center username-profile">Nom d'utilisateur</li>
				{% else %}
					<li class="fs-5 align-items-center username-profile">{{ app.user.username }}</li>
				{% endif %}
			</ul>
			<div class="d-flex flex-row align-items-center list-unstyled profile-btns">
				<a class="btn btn-sm btn-outline-secondary" href="{{ path('user_settings') }}">
					<i class="fa-solid fa-gear"></i>Paramètres du profil</a>
				{# <a href="{{ path('app_logout') }}" class="ms-3 btn btn-outline-danger text-decoration-none" id="logout">
					<i class="fa-solid fa-arrow-right-from-bracket"></i>Se déconnecter</a> #}
				{# <li class="btn btn-sm btn-outline-secondary mt-2 subscribe-btn">S'abonner</li> #}
			</div>
		</div>
		<div class="d-flex flex-row justify-content-center align-items-center profile-btns" id="posts-btns">
			<a href="{{ path('post_create') }}" class="me-4 btn btn-outline-success">
				<i class="fa-solid fa-plus"></i>Créer un nouveau post</a>
			<a href="#" class="profile-btns btn btn-outline-danger">
				<i class="fa-solid fa-minus"></i>Supprimer des posts</a>
		</div>
		<div class="row mb-5" id="posts">
			<div>
				<ul class="list-unstyled d-flex flex-row justify-content-between">
					<li class="fs-2">Vos publications</li>
				</ul>
			</div>
		</div>
		<div class="row mb-2 m-0">
			{# Conteneur parent des cartes #}
			<div class="row mb-2 m-0">
			{% for post in posts %}
				{% if app.user.id == post.myUser.id %}
					{# Conteneur parent de l'une des cartes #}
					<div class="col-md-6 m-0" id="{{ post.myUser.id }}">
						{# Conteneur enfant de la carte #}
						{#  h-md-250 #}
						<div class="row g-0 border rounded overflow-hidden flex-md-row mb-4 shadow-sm position-relative post-height">
							{# Contenu de la carte #}
							<div class="col-6 p-4 d-flex flex-column position-static">
								<strong class="d-inline-block mb-2 text-success-emphasis">{{ post.category.name }}</strong>
								<h3 class="mb-3">{{ post.title }}</h3>
								<div class="mb-3 text-body-secondary">{{ post.createdAt | date("d/m/Y") }}</div>
								<p class="mb-auto">{{ post.content }}</p>
								<a href="#" class="icon-link gap-1 icon-link-hover stretched-link">
									Lire la suite
									<svg class="bi" aria-hidden="true">
										<use xlink:href="#chevron-right"></use>
									</svg>
								</a>
							</div>
							<div class="col-6 d-lg-flex d-inline-block post-image" style="background-image:url('{{ asset('uploads/images/' ~ post.imageName) }}')" alt="{{ post.imageName }}"></div>
						</div>
					</div>
				{% endif %}
			{% endfor %}
			</div>
		</div>
	</main>
{# Fin MAIN #}
{% endblock %}
